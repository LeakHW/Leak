{
  "manifest_version": 3,
  "name": "Leak",
  "version": "1.0",
  "description": "Leak homework helper",
  "action": {
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://141.147.118.157:5678/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://app.senecalearning.com/login/*"
      ],
      "js": [
        "universal/tools.js",
        "seneca/auth/tool-config.js",
        "seneca/auth/index.js",
        "seneca/universal.js"
      ],
      "css": [
        "seneca/universal.css",
        "seneca/auth/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://app.senecalearning.com/dashboard/*",
        "*://app.senecalearning.com/dashboard"
      ],
      "js": [
        "universal/tools.js",
        "seneca/app/tool-config.js",
        "seneca/app/index.js",
        "seneca/universal.js"
      ],
      "css": [
        "seneca/universal.css",
        "seneca/app/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://maths.sparx-learning.com/*"
      ],
      "js": [
        "universal/tools.js",
        "sparx/maths/tool-config.js",
        "sparx/maths/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/maths/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://reader.sparx-learning.com/*"
      ],
      "js": [
        "universal/tools.js",
        "sparx/reader/tool-config.js",
        "sparx/reader/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/reader/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://science.sparx-learning.com/*"
      ],
      "js": [
        "universal/tools.js",
        "sparx/science/tool-config.js",
        "sparx/science/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/science/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://auth.sparx-learning.com/*"
      ],
      "js": [
        "universal/tools.js",
        "sparx/auth/index.js",
        "sparx/universal.js"
      ],
      "css": [
        "sparx/universal.css",
        "sparx/auth/index.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "universal/tools.js",
        "universal/tools/leak_menu/leak_menu.js",
        "universal/tools/chatbot/chatbot.js",
        "universal/tools/example/example.js",
        "universal/tools/data_collector/data_collector.js",
        "universal/tools/bookwork_helper/bookwork_helper.js",
        "universal/tools/dev_info/dev_info.js",
        "universal/tools/text_selector/text_selector.js",
        "universal/tools/scientific_calculator/scientific_calculator.js"
      ],
      "css": [
        "universal/tools/leak_menu/leak_menu.css",
        "universal/tools/chatbot/chatbot.css",
        "universal/tools/example/example.css",
        "universal/tools/dev_info/dev_info.css",
        "universal/tools/scientific_calculator/scientific_calculator.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "universal/tools/leak_menu/leak_menu.html",
        "universal/tools/chatbot/chatbot.html",
        "universal/tools/example/example.html",
        "universal/tools/scientific_calculator/scientific_calculator.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
